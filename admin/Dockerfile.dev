FROM node:20-alpine

# Install libc6-compat for dependencies expecting glibc (important on Alpine).
# Add build toolchain packages only if native modules are required.
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Enable corepack
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy lock file and package manifest first for better layer caching.
COPY package.json pnpm-lock.yaml ./

# Install dependencies for the linux-musl target.
RUN pnpm install --frozen-lockfile

COPY . .

EXPOSE 5174

CMD ["pnpm", "dev", "--host", "--port", "5174"]
